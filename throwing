local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Throwing Simulator OP",
    LoadingTitle = "Sabar NYETT..",
    LoadingSubtitle = "by vanzzmmt",
    ConfigurationSaving = {
        Enabled = false
    }
})

local MainTab = Window:CreateTab("Main", 4483362458)
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local player = Players.LocalPlayer
local remoteEvent = ReplicatedStorage.Paper.Remotes.__remoteevent
local remoteFunction = ReplicatedStorage.Paper.Remotes.__remotefunction
local autoThrow = false
local autoHatch = false
local autoRebirth = false


MainTab:CreateToggle({
    Name = "Auto Throw (Stable)",
    CurrentValue = false,
    Callback = function(Value)
        autoThrow = Value

        if autoThrow then
            task.spawn(function()
                while autoThrow do
                    pcall(function()
                        remoteEvent:FireServer("Throw Object")
                    end)

                    task.wait(1.25)

                    pcall(function()
                        remoteEvent:FireServer("Landed")
                    end)

                    task.wait(0.5)
                end
            end)
        end
    end
})

MainTab:CreateToggle({
    Name = "Auto Hatch",
    CurrentValue = false,
    Callback = function(Value)
        autoHatch = Value

        if autoHatch then
            task.spawn(function()
                while autoHatch do
                    pcall(function()
                        remoteFunction:InvokeServer("Hatch Egg", "Farm Egg", "Max")
                    end)
                    task.wait(0.5)
                end
            end)
        end
    end
})

MainTab:CreateToggle({
    Name = "Auto Rebirth",
    CurrentValue = false,
    Callback = function(Value)
        autoRebirth = Value

        if autoRebirth then
            task.spawn(function()
                while autoRebirth do
                    pcall(function()
                        remoteFunction:InvokeServer("Rebirth", 21)
                    end)
                    task.wait(2) -- biar aman ga spam
                end
            end)
        end
    end
})

